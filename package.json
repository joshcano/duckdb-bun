{
  "name": "@joshcano/duckdb-bun",
  "version": "1.5.2-r.1",
  "description": "Bun-native, drop-in reimplementation of @duckdb/node-api via bun:ffi over the libduckdb C API. Embeds libduckdb so `bun build --compile` yields a self-contained binary.",
  "author": "Josh Cano (https://github.com/joshcano)",
  "homepage": "https://github.com/joshcano/duckdb-bun#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshcano/duckdb-bun.git"
  },
  "bugs": {
    "url": "https://github.com/joshcano/duckdb-bun/issues"
  },
  "type": "module",
  "module": "src/neo.ts",
  "types": "src/neo.ts",
  "exports": {
    ".": "./src/neo.ts",
    "./native-js": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "native",
    "scripts/fetch-lib.ts",
    "vendor/duckdb.h",
    "vendor/linux-x64",
    "vendor/node-api/src",
    "vendor/node-api/LICENSE",
    "vendor/node-api/PROVENANCE.md"
  ],
  "scripts": {
    "fetch-lib": "bun run scripts/fetch-lib.ts",
    "spike": "bun run scripts/spike.ts",
    "test": "bun test",
    "test:official": "bun test tests/official/api.test.ts",
    "gen:bindings": "bun run scripts/gen-bindings-scaffold.ts",
    "build:neo": "bun run scripts/build-neo-compile.ts",
    "parity": "bun test tests/parity.test.ts",
    "check-version": "bun run scripts/check-version.ts",
    "lint": "biome check src tests scripts examples",
    "format": "biome format --write src tests scripts examples",
    "check": "biome check --write src tests scripts examples",
    "ci": "biome check src tests scripts examples && bun test"
  },
  "keywords": ["duckdb", "bun", "ffi", "sql", "analytics"],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@duckdb/node-api": "1.5.2-r.1",
    "@types/bun": "latest"
  }
}
